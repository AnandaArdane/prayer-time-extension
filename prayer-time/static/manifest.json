{
  "manifest_version": 3,
  "name": "Jadwal Sholat & Kajian",
  "version": "1.0.0",
  "description": "Aplikasi Jadwal Sholat dan Kajian Masjid.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "geolocation"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://nominatim.openstreetmap.org/*"
  ]
}
